{
    "redirects": [
        {
            "source": "/",
            "destination": "/de/index.html",
            "permanent": false
        }
    ],
    "headers": [
        {
            "source": "/de/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/en/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}